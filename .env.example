# ─────────────────────────────────────────────
# .env.example — Copier en .env et adapter
# Ne jamais committer le fichier .env réel !
# ─────────────────────────────────────────────

CI_ENVIRONMENT = development

# URL de base
app.baseURL = 'http://localhost/'

# Base de données
database.default.hostname = db
database.default.database = foodmarket
database.default.username = fooduser
database.default.password = foodpass
database.default.DBDriver = MySQLi
database.default.port     = 3306

# JWT — CHANGER EN PRODUCTION
JWT_SECRET = foodmarket_secret_key_change_in_production
