{
    "name": "foodmarket/app",
    "description": "Projet e-commerce alimentaire - CodeIgniter 4",
    "type": "project",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.4"
    },
    "require-dev": {
        "codeigniter4/devkit": "^1.3",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --coverage-text",
        "lint": "php -l app/**/*.php"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
